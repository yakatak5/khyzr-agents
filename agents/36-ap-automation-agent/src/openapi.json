{
  "openapi": "3.0.0",
  "info": {
    "title": "AP Automation Agent API",
    "description": "Accounts payable automation tools for invoice processing, PO matching, discrepancy detection, approval routing, and ledger updates",
    "version": "1.0.0"
  },
  "paths": {
    "/extract-invoice-data": {
      "post": {
        "summary": "Extract structured data from an invoice PDF or text",
        "description": "Parses an invoice and returns vendor name, invoice number, line items, amounts, PO reference, and payment terms",
        "operationId": "extractInvoiceData",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "invoice_source": {
                    "type": "string",
                    "description": "S3 URI, file path, or base64-encoded invoice content"
                  }
                },
                "required": ["invoice_source"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extracted invoice data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "invoice_number": {"type": "string"},
                    "vendor_name": {"type": "string"},
                    "total_amount": {"type": "number"},
                    "line_items": {"type": "array"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/match-purchase-order": {
      "post": {
        "summary": "Match invoice against a purchase order",
        "description": "Performs three-way match between invoice, PO, and goods receipt. Returns variance analysis and match status.",
        "operationId": "matchPurchaseOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "po_number": {
                    "type": "string",
                    "description": "Purchase order number to match against"
                  },
                  "invoice_data": {
                    "type": "string",
                    "description": "JSON string of extracted invoice data from extract-invoice-data"
                  }
                },
                "required": ["po_number", "invoice_data"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Three-way match result with variance analysis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "match_status": {"type": "string"},
                    "variance_pct": {"type": "number"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/flag-discrepancies": {
      "post": {
        "summary": "Evaluate match results and flag discrepancies",
        "description": "Classifies discrepancies by severity (critical/high/warning) and recommends actions including payment holds",
        "operationId": "flagDiscrepancies",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "match_result": {
                    "type": "string",
                    "description": "JSON string from match-purchase-order"
                  }
                },
                "required": ["match_result"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Discrepancy analysis with severity classifications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "invoice_status": {"type": "string"},
                    "discrepancies": {"type": "array"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/route-for-approval": {
      "post": {
        "summary": "Route invoice to appropriate approver",
        "description": "Determines the correct approver based on discrepancy severity and sends approval notification",
        "operationId": "routeForApproval",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "invoice_number": {
                    "type": "string",
                    "description": "Invoice number to route"
                  },
                  "discrepancy_data": {
                    "type": "string",
                    "description": "JSON string from flag-discrepancies"
                  },
                  "approver_email": {
                    "type": "string",
                    "description": "Optional override approver email"
                  }
                },
                "required": ["invoice_number", "discrepancy_data"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Routing confirmation with assigned approver",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "routing_status": {"type": "string"},
                    "assigned_to": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/update-ap-ledger": {
      "post": {
        "summary": "Record invoice in the AP ledger",
        "description": "Creates a ledger entry in DynamoDB with invoice details, GL coding, and approval status",
        "operationId": "updateApLedger",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "invoice_number": {
                    "type": "string",
                    "description": "Invoice number to record"
                  },
                  "invoice_data": {
                    "type": "string",
                    "description": "JSON string of invoice details"
                  },
                  "approval_status": {
                    "type": "string",
                    "description": "Current status: pending, approved, rejected, or paid"
                  }
                },
                "required": ["invoice_number", "invoice_data"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ledger entry confirmation with transaction ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transaction_id": {"type": "string"},
                    "status": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
